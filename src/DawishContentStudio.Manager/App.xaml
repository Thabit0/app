<Application x:Class="DawishContentStudio.Manager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Color x:Key="BgColor">#F7F1E8</Color>
        <SolidColorBrush x:Key="DawishBg" Color="#F7F1E8"/>
        <SolidColorBrush x:Key="DawishBrown" Color="#3D2617"/>
        <SolidColorBrush x:Key="DawishGold" Color="#C89B52"/>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
        </Style>
    </Application.Resources>
</Application>
