<Window x:Class="DawishContentStudio.Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dawish Content Studio v0.8" Height="900" Width="1500"
        FlowDirection="RightToLeft" WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="295"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="1" Background="{StaticResource Dark}" CornerRadius="32" Margin="18" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel>
                    <Border Background="#203027" CornerRadius="20" Padding="16" Margin="0,0,0,14">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Dawish" Foreground="White" FontSize="31" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Content Studio" Foreground="#F4D8A8" FontSize="17" HorizontalAlignment="Center"/>
                            <TextBlock Text="v0.8 Cloudflare — برنامج واحد سهل" Foreground="#D9E1D6" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#F5E5BF" CornerRadius="22" Padding="12" Margin="0,0,0,12">
                        <TextBlock x:Name="RoleBadgeText" Text="لم يتم اختيار وضع الجهاز" Foreground="#1F2A20" FontWeight="Bold" TextAlignment="Center"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <Button x:Name="NavStart" Style="{StaticResource NavButton}" Content="🔐 البداية والدخول" Click="ShowStart_Click"/>
                    <Button x:Name="NavDashboard" Style="{StaticResource NavButton}" Content="🏠 لوحة التحكم" Click="ShowDashboard_Click"/>
                    <Button x:Name="NavPosts" Style="{StaticResource NavButton}" Content="🖼 رفع الصور وجدولتها" Click="ShowPosts_Click"/>
                    <Button x:Name="NavQueue" Style="{StaticResource NavButton}" Content="🛒 جهاز المحل" Click="ShowShop_Click"/>
                    <Button x:Name="NavSettings" Style="{StaticResource NavButton}" Content="⚙ الإعدادات" Click="ShowSettings_Click"/>
                </StackPanel>
                <StackPanel Grid.Row="2">
                    <Separator Background="#536154" Margin="0,8"/>
                    <TextBlock Text="الثوابت" Foreground="#F4D8A8" FontWeight="Bold"/>
                    <TextBlock Text="Cloudflare للمزامنة فقط. لا نستخدم API لإنستا أو تيك أو سناب. TikTok صورة فقط. Snapchat صورة فقط." Foreground="#E8EEE8" TextWrapping="Wrap" Margin="0,6,0,10"/>
                    <TextBlock x:Name="ConnectionStatusText" Text="غير متصل" Foreground="White" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="0" Margin="18,18,0,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="{StaticResource Panel}" CornerRadius="26" Padding="18" BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Dawish Content Studio" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="أنت ترفع وتجدول. جهاز المحل يسحب من Cloudflare وينشر من الحسابات الموجودة عنده." Foreground="{StaticResource Muted}" FontSize="15" Margin="0,4,0,0"/>
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button Content="فحص الاتصال" Click="TestConnection_Click"/>
                        <Button Style="{StaticResource PrimaryButton}" Content="تحديث" Click="Refresh_Click"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <TabControl x:Name="MainTabs" Grid.Row="1" BorderThickness="0" Background="Transparent" SelectedIndex="0">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Height" Value="0"/><Setter Property="Width" Value="0"/><Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0"/>
                    </Style>
                </TabControl.ItemContainerStyle>

                <TabItem Header="Start">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource Card}" Background="#FFF8EA">
                                <StackPanel>
                                    <TextBlock Text="أول تشغيل" FontSize="30" FontWeight="Bold"/>
                                    <TextBlock Text="اختر طريقة استخدام هذا الجهاز. نفس البرنامج يشتغل عندك وعند جهاز المحل." Foreground="{StaticResource Muted}" FontSize="16" Margin="0,6,0,16"/>
                                    <UniformGrid Columns="2">
                                        <Border Style="{StaticResource Card}">
                                            <StackPanel>
                                                <TextBlock Text="أنا المدير" FontSize="24" FontWeight="Bold"/>
                                                <TextBlock Text="أرفع الصور، أكتب الكابشن، أحدد الوقت واللوكيشن، وأرسلها إلى Cloudflare." TextWrapping="Wrap" Foreground="{StaticResource Muted}" Margin="0,8,0,12"/>
                                                <Button Style="{StaticResource PrimaryButton}" Content="اختيار هذا الجهاز كمدير" Click="SetAdminRole_Click"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource Card}">
                                            <StackPanel>
                                                <TextBlock Text="هذا جهاز المحل" FontSize="24" FontWeight="Bold"/>
                                                <TextBlock Text="الحسابات تكون هنا. الجهاز يسحب المنشورات المستحقة ويفتحها للنشر." TextWrapping="Wrap" Foreground="{StaticResource Muted}" Margin="0,8,0,12"/>
                                                <Button Style="{StaticResource PrimaryButton}" Content="اختيار هذا الجهاز كمحل" Click="SetShopRole_Click"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="ربط Cloudflare" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="ضع رابط Worker والرمز المناسب. المدير يستخدم ADMIN_TOKEN وجهاز المحل يستخدم SHOP_TOKEN." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,12"/>
                                    <TextBlock Style="{StaticResource SmallLabel}" Text="Worker URL"/>
                                    <TextBox x:Name="WorkerUrlTextBox" Text="https://dawish-content-api.thabit1919.workers.dev" FlowDirection="LeftToRight" TextAlignment="Left"/>
                                    <TextBlock Style="{StaticResource SmallLabel}" Text="الرمز"/>
                                    <PasswordBox x:Name="TokenPasswordBox" FlowDirection="LeftToRight"/>
                                    <WrapPanel>
                                        <Button Style="{StaticResource PrimaryButton}" Content="حفظ الإعدادات" Click="SaveSettings_Click"/>
                                        <Button Content="فحص الاتصال" Click="TestConnection_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Dashboard">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <UniformGrid Columns="4">
                                <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="الاتصال" Foreground="{StaticResource Muted}" FontWeight="Bold"/><TextBlock x:Name="CloudStatusCardText" Text="غير مفحوص" FontSize="25" FontWeight="Bold" Margin="0,8,0,0"/></StackPanel></Border>
                                <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="جهاز المحل" Foreground="{StaticResource Muted}" FontWeight="Bold"/><TextBlock x:Name="ShopStatusCardText" Text="غير معروف" FontSize="25" FontWeight="Bold" Margin="0,8,0,0"/></StackPanel></Border>
                                <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="منشورات قادمة" Foreground="{StaticResource Muted}" FontWeight="Bold"/><TextBlock x:Name="UpcomingCardText" Text="0" FontSize="30" FontWeight="Bold" Margin="0,8,0,0"/></StackPanel></Border>
                                <Border Style="{StaticResource Card}" Background="{StaticResource Dark}"><StackPanel><TextBlock Text="القواعد" Foreground="#F4D8A8" FontWeight="Bold"/><TextBlock Text="ثابتة" Foreground="White" FontSize="30" FontWeight="Bold"/><TextBlock Text="TikTok صورة فقط / Snapchat صورة فقط" Foreground="#D9E1D6" TextWrapping="Wrap"/></StackPanel></Border>
                            </UniformGrid>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="المسار السهل" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="1) ارفع الصور  2) اكتب الكابشن  3) حدد اللوكيشن والوقت  4) اضغط رفع وجدولة  5) جهاز المحل يسحبها وقت النشر." Foreground="{StaticResource Muted}" FontSize="18" TextWrapping="Wrap" Margin="0,8,0,12"/>
                                    <Button Style="{StaticResource PrimaryButton}" Content="ابدأ برفع الصور" Click="ShowPosts_Click" Width="210" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Posts">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*"/>
                            <ColumnDefinition Width="1.25*"/>
                            <ColumnDefinition Width="0.9*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Text="الصور" FontSize="26" FontWeight="Bold"/>
                                    <TextBlock Text="ارفع صورة أو أكثر، ثم اختر صورة وعدّل بياناتها." Foreground="{StaticResource Muted}" Margin="0,4,0,8"/>
                                    <Button Style="{StaticResource PrimaryButton}" Content="رفع صور" Click="ChooseImages_Click"/>
                                    <Button Content="جدولة كل الصور المختارة" Click="ScheduleAllImages_Click"/>
                                </StackPanel>
                                <ListBox x:Name="ImagesListBox" SelectionChanged="ImagesListBox_SelectionChanged" Margin="0,10,0,0" FontSize="14"/>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="بيانات الصورة المحددة" FontSize="26" FontWeight="Bold"/>
                                    <TextBlock Text="لا يوجد عنوان. الكابشن هو الأساس." Foreground="{StaticResource Muted}" Margin="0,4,0,10"/>
                                    <Image x:Name="SelectedImagePreview" Height="180" Stretch="Uniform" Margin="0,4,0,12"/>
                                    <TextBlock Style="{StaticResource SmallLabel}" Text="الكابشن الأساسي"/>
                                    <TextBox x:Name="CaptionTextBox" AcceptsReturn="True" Height="95" TextChanged="PostFields_Changed" Text="متوفر الآن في عطارة الدويش."/>
                                    <UniformGrid Columns="3" Margin="0,6,0,6">
                                        <CheckBox x:Name="InstagramCheckBox" Content="Instagram" IsChecked="True" Checked="PostFields_Changed" Unchecked="PostFields_Changed"/>
                                        <CheckBox x:Name="TikTokCheckBox" Content="TikTok" IsChecked="True" Checked="PostFields_Changed" Unchecked="PostFields_Changed"/>
                                        <CheckBox x:Name="SnapchatCheckBox" Content="Snapchat" IsChecked="False" Checked="PostFields_Changed" Unchecked="PostFields_Changed"/>
                                    </UniformGrid>
                                    <TextBlock Style="{StaticResource SmallLabel}" Text="لوكيشن Instagram"/>
                                    <TextBox x:Name="InstagramLocationTextBox" Text="مدينة الزلفي" TextChanged="PostFields_Changed"/>
                                    <TextBlock Style="{StaticResource SmallLabel}" Text="لوكيشن TikTok"/>
                                    <TextBox x:Name="TikTokLocationTextBox" Text="عطارة الدويش" TextChanged="PostFields_Changed"/>
                                    <TextBlock Style="{StaticResource SmallLabel}" Text="لوكيشن Snapchat"/>
                                    <TextBox x:Name="SnapchatLocationTextBox" Text="" TextChanged="PostFields_Changed"/>
                                    <TextBlock Style="{StaticResource SmallLabel}" Text="وقت النشر 12 ساعة"/>
                                    <WrapPanel>
                                        <DatePicker x:Name="ScheduleDatePicker" SelectedDateChanged="PostFields_Changed" Width="150"/>
                                        <ComboBox x:Name="HourComboBox" SelectionChanged="PostFields_Changed" Width="76"/>
                                        <ComboBox x:Name="MinuteComboBox" SelectionChanged="PostFields_Changed" Width="76"/>
                                        <ComboBox x:Name="AmPmComboBox" SelectionChanged="PostFields_Changed" Width="76">
                                            <ComboBoxItem Content="ص"/>
                                            <ComboBoxItem Content="م" IsSelected="True"/>
                                        </ComboBox>
                                    </WrapPanel>
                                    <TextBlock Style="{StaticResource SmallLabel}" Text="للتعديل الجماعي: الفرق بين الصور بالدقائق"/>
                                    <ComboBox x:Name="SpacingMinutesComboBox" Width="110" HorizontalAlignment="Right">
                                        <ComboBoxItem Content="30"/>
                                        <ComboBoxItem Content="60" IsSelected="True"/>
                                        <ComboBoxItem Content="120"/>
                                        <ComboBoxItem Content="1440"/>
                                    </ComboBox>
                                    <WrapPanel>
                                        <Button Style="{StaticResource PrimaryButton}" Content="رفع وجدولة المحدد" Click="ScheduleSelectedImage_Click"/>
                                        <Button Content="تطبيق هذه البيانات على كل الصور" Click="ApplyToAllImages_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="المعاينة" FontSize="26" FontWeight="Bold"/>
                                <Border Background="#101010" CornerRadius="26" Padding="14" Margin="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock x:Name="PreviewPlatformText" Text="Instagram / TikTok / Snapchat" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <Border Background="#F0F0F0" CornerRadius="16" Height="220" Margin="0,12">
                                            <Grid><Image x:Name="PhoneImagePreview" Stretch="Uniform"/><TextBlock x:Name="EmptyImageText" Text="صورة المنشور" Foreground="#888" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid>
                                        </Border>
                                        <TextBlock x:Name="PreviewCaptionText" Text="الكابشن يظهر هنا" Foreground="White" TextWrapping="Wrap"/>
                                        <TextBlock x:Name="PreviewLocationText" Text="اللوكيشن" Foreground="#F4D8A8" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                        <TextBlock Text="TikTok: صورة فقط وبدون صوت — Snapchat: صورة فقط" Foreground="#D9E1D6" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="UploadStatusText" Text="" TextWrapping="Wrap" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Shop">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="جهاز المحل" FontSize="28" FontWeight="Bold"/>
                                <TextBlock Text="هذا الوضع يكون في جهاز المحل الذي عليه الحسابات. يسحب المنشورات من Cloudflare ويفتح صفحة مساعدة للنشر." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,12"/>
                                <WrapPanel>
                                    <Button Style="{StaticResource PrimaryButton}" Content="تشغيل محطة المحل" Click="StartShopStation_Click"/>
                                    <Button Style="{StaticResource DangerButton}" Content="إيقاف" Click="StopShopStation_Click"/>
                                    <Button Content="فحص الآن" Click="RunShopOnce_Click"/>
                                </WrapPanel>
                                <TextBlock x:Name="ShopStationText" Text="محطة المحل متوقفة" FontSize="18" FontWeight="Bold" Margin="0,12,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Text="المنشورات القادمة / المستحقة" FontSize="26" FontWeight="Bold"/>
                                    <Button Content="تحديث القائمة" Click="RefreshDuePosts_Click"/>
                                </StackPanel>
                                <ListBox x:Name="DuePostsListBox" Margin="0,12,0,0" FontSize="14"/>
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="الإعدادات" FontSize="28" FontWeight="Bold"/>
                                    <TextBlock Style="{StaticResource SmallLabel}" Text="Worker URL"/>
                                    <TextBox x:Name="SettingsWorkerUrlTextBox" FlowDirection="LeftToRight" TextAlignment="Left"/>
                                    <TextBlock Style="{StaticResource SmallLabel}" Text="Token"/>
                                    <PasswordBox x:Name="SettingsTokenPasswordBox" FlowDirection="LeftToRight"/>
                                    <TextBlock Style="{StaticResource SmallLabel}" Text="وضع الجهاز"/>
                                    <ComboBox x:Name="RoleComboBox" Width="220" HorizontalAlignment="Right">
                                        <ComboBoxItem Content="أنا المدير" Tag="admin"/>
                                        <ComboBoxItem Content="هذا جهاز المحل" Tag="shop"/>
                                    </ComboBox>
                                    <WrapPanel>
                                        <Button Style="{StaticResource PrimaryButton}" Content="حفظ" Click="SaveSettingsFromSettingsTab_Click"/>
                                        <Button Content="فحص الاتصال" Click="TestConnection_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
