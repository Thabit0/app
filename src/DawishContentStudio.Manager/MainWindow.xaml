<Window x:Class="DawishContentStudio.Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dawish Content Studio v0.7" Height="920" Width="1540"
        FlowDirection="RightToLeft" WindowStartupLocation="CenterScreen"
        Background="{StaticResource DawishBg}">
    <Grid Background="{StaticResource DawishBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="310"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="1" Background="{StaticResource DawishAccentDark}" CornerRadius="34" Margin="20,18,18,18" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Background="#203027" CornerRadius="22" Padding="16" Margin="0,0,0,14">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Dawish" Foreground="White" FontSize="31" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Content Studio" Foreground="#F4D8A8" FontSize="17" HorizontalAlignment="Center"/>
                            <TextBlock Text="v0.7 — برنامج واحد للابتوب وجهاز المحل" Foreground="#D9E1D6" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#F5E5BF" CornerRadius="22" Padding="12" Margin="0,0,0,14">
                        <TextBlock x:Name="DeviceModeBadgeText" Text="الوضع: جهاز الإدارة" Foreground="#1F2A20" FontWeight="Bold" TextAlignment="Center"/>
                    </Border>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Button Style="{StaticResource NavButton}" Content="🏠 لوحة التحكم" Click="ShowDashboard_Click"/>
                        <Button Style="{StaticResource NavButton}" Content="🚀 أول تشغيل" Click="ShowOnboarding_Click"/>
                        <Button Style="{StaticResource NavButton}" Content="📝 المنشورات" Click="ShowPosts_Click"/>
                        <Button Style="{StaticResource NavButton}" Content="🧩 التعديل الجماعي" Click="ShowBulk_Click"/>
                        <Button Style="{StaticResource NavButton}" Content="✅ مركز الاعتماد" Click="ShowApprovalCenter_Click"/>
                        <Button Style="{StaticResource NavButton}" Content="📱 المعاينة" Click="ShowPreview_Click"/>
                        <Button Style="{StaticResource NavButton}" Content="🖥 جهاز المحل والمزامنة" Click="ShowDevice_Click"/>
                        <Button Style="{StaticResource NavButton}" Content="📚 الأرشيف والسجل" Click="ShowArchive_Click"/>
                        <Button Style="{StaticResource NavButton}" Content="⚙ الإعدادات" Click="ShowSettings_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="0,14,0,0">
                    <Separator Background="#536154" Margin="0,8"/>
                    <TextBlock Text="القواعد الثابتة" Foreground="#F4D8A8" FontWeight="Bold"/>
                    <TextBlock Text="بدون API نهائيًا. TikTok صورة فقط وبدون صوت. Snapchat صورة فقط. منع الكلام الطبي." Foreground="#E8EEE8" TextWrapping="Wrap" Margin="0,6,0,12"/>
                    <TextBlock x:Name="HeartbeatText" Foreground="White" TextWrapping="Wrap" Text="جهاز المحل: لا يوجد heartbeat" Margin="0,0,0,10"/>
                    <Button Content="تحديث البيانات" Click="Refresh_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="0" Margin="18,18,0,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="{StaticResource DawishPanel}" CornerRadius="28" Padding="18" BorderBrush="{StaticResource DawishBorder}" BorderThickness="1" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Dawish Content Studio" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="واجهة v0.7: جهازك يجهز، وجهاز المحل يلتقط من مجلد المزامنة وينفذ بدون API." Foreground="{StaticResource DawishMuted}" FontSize="15" Margin="0,4,0,0"/>
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Button Content="اختيار مجلد المزامنة" Click="ChooseFolder_Click"/>
                        <Button Style="{StaticResource PrimaryButton}" Content="تحديث" Click="Refresh_Click"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <TabControl x:Name="MainTabs" Grid.Row="1" BorderThickness="0" Background="Transparent" SelectedIndex="0">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Height" Value="0"/>
                        <Setter Property="Width" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </TabControl.ItemContainerStyle>

                <TabItem Header="Dashboard">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <UniformGrid Columns="5" Margin="0,0,0,8">
                                <Border Style="{StaticResource MiniCard}">
                                    <StackPanel>
                                        <TextBlock Text="حالة المزامنة" Foreground="{StaticResource DawishMuted}" FontWeight="Bold"/>
                                        <TextBlock x:Name="SyncStateCardText" Text="جاهزة" FontSize="26" FontWeight="Bold" Margin="0,8,0,0"/>
                                        <TextBlock x:Name="SyncFolderShortText" Text="DawishSync" Foreground="{StaticResource DawishMuted}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MiniCard}">
                                    <StackPanel>
                                        <TextBlock Text="جهاز المحل" Foreground="{StaticResource DawishMuted}" FontWeight="Bold"/>
                                        <TextBlock x:Name="ShopDeviceCardText" Text="غير متصل" FontSize="26" FontWeight="Bold" Margin="0,8,0,0"/>
                                        <TextBlock Text="Heartbeat" Foreground="{StaticResource DawishMuted}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MiniCard}">
                                    <StackPanel>
                                        <TextBlock Text="المنشورات" Foreground="{StaticResource DawishMuted}" FontWeight="Bold"/>
                                        <TextBlock x:Name="TotalJobsCardText" Text="0" FontSize="30" FontWeight="Bold" Margin="0,6,0,0"/>
                                        <TextBlock Text="داخل مجلد المزامنة" Foreground="{StaticResource DawishMuted}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MiniCard}">
                                    <StackPanel>
                                        <TextBlock Text="جاهز/ينتظر" Foreground="{StaticResource DawishMuted}" FontWeight="Bold"/>
                                        <TextBlock x:Name="PendingJobsCardText" Text="0" FontSize="30" FontWeight="Bold" Margin="0,6,0,0"/>
                                        <TextBlock Text="قبل النشر أو التأكيد" Foreground="{StaticResource DawishMuted}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MiniCard}" Background="{StaticResource DawishAccentDark}">
                                    <StackPanel>
                                        <TextBlock Text="القواعد" Foreground="#F4D8A8" FontWeight="Bold"/>
                                        <TextBlock Text="ثابتة" Foreground="White" FontSize="30" FontWeight="Bold" Margin="0,6,0,0"/>
                                        <TextBlock Text="بدون API / تيك صورة / سناب صورة" Foreground="#D9E1D6" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Style="{StaticResource Card}" Margin="8" Background="#FFF9EE">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="ابدأ من هنا" FontSize="24" FontWeight="Bold"/>
                                        <TextBlock Text="اختصرنا خطوات التشغيل: اختر المجلد، حدد وضع هذا الجهاز، ثم ابدأ إنشاء المنشورات أو شغّل محطة النشر في جهاز المحل." Foreground="{StaticResource DawishMuted}" TextWrapping="Wrap" Margin="0,6,0,14"/>
                                        <WrapPanel>
                                            <Button Style="{StaticResource PrimaryButton}" Content="اختيار مجلد المزامنة" Click="ChooseFolder_Click" MinWidth="180"/>
                                            <Button Content="أول تشغيل" Click="ShowOnboarding_Click" MinWidth="130"/>
                                        </WrapPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#173023" CornerRadius="20" Padding="16" Margin="12,0">
                                        <StackPanel>
                                            <TextBlock Text="جهاز الإدارة" Foreground="#F4D8A8" FontWeight="Bold"/>
                                            <TextBlock Text="إنشاء المنشورات، التعديل الجماعي، المعاينة، الاعتماد، ثم إرسال الملفات إلى DawishSync." Foreground="White" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="#2F5F51" CornerRadius="20" Padding="16" Margin="12,0">
                                        <StackPanel>
                                            <TextBlock Text="جهاز المحل" Foreground="#F4D8A8" FontWeight="Bold"/>
                                            <TextBlock Text="تشغيل محطة النشر، قراءة jobs من المزامنة، فتح المنصات، وإرجاع الحالة للابتوب." Foreground="White" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="اختصارات العمل" FontSize="22" FontWeight="Bold"/>
                                        <TextBlock Text="أهم العمليات بدون زحمة. اختر ما تريد من هنا أو من القائمة الجانبية." Foreground="{StaticResource DawishMuted}" Margin="0,4,0,14"/>
                                        <WrapPanel>
                                            <Button Style="{StaticResource PrimaryButton}" Content="منشور جديد" Click="ShowPosts_Click" MinWidth="150"/>
                                            <Button Style="{StaticResource PrimaryButton}" Content="تعديل جماعي" Click="ShowBulk_Click" MinWidth="150"/>
                                            <Button Content="تشغيل محطة النشر" Click="StartLocalPublisher_Click" MinWidth="170"/>
                                            <Button Content="فحص الآن" Click="RunLocalPublisherOnce_Click" MinWidth="120"/>
                                        </WrapPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                        <TextBlock Text="نبض النظام" FontSize="22" FontWeight="Bold"/>
                                        <TextBlock Text="آخر ما حدث في المنشورات والمزامنة والحسابات." Foreground="{StaticResource DawishMuted}"/>
                                        <UniformGrid Columns="2" Margin="0,16,0,0">
                                            <Border Style="{StaticResource Card}" Margin="4" Padding="14">
                                                <StackPanel>
                                                    <TextBlock Text="آخر حالة" Foreground="{StaticResource DawishMuted}"/>
                                                    <TextBlock x:Name="LastStatusCardText" Text="لا يوجد" FontWeight="Bold" FontSize="18" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource Card}" Margin="4" Padding="14">
                                                <StackPanel>
                                                    <TextBlock Text="محطة النشر" Foreground="{StaticResource DawishMuted}"/>
                                                    <TextBlock x:Name="DashboardPublisherText" Text="متوقفة" FontWeight="Bold" FontSize="18" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Posts">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="410"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="منشور جديد" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="الصورة والكابشن والجدولة ترسل كـ Job مستقل إلى مجلد المزامنة." Foreground="{StaticResource DawishMuted}" TextWrapping="Wrap" Margin="0,4,0,12"/>

                                    <TextBlock Text="العنوان" Margin="0,10,0,3"/>
                                    <TextBox x:Name="TitleTextBox" Height="36" Text="منشور جديد"/>

                                    <TextBlock Text="الصورة" Margin="0,10,0,3"/>
                                    <TextBox x:Name="ImagePathTextBox" Height="36" Text="اختر صورة" IsReadOnly="True"/>
                                    <Button Content="اختيار صورة" Click="ChooseImage_Click"/>

                                    <TextBlock Text="تاريخ ووقت النشر" Margin="0,10,0,3"/>
                                    <DatePicker x:Name="ScheduleDatePicker"/>
                                    <TextBox x:Name="ScheduleTimeTextBox" Height="36" Text="19:00" Margin="0,6,0,0"/>

                                    <TextBlock Text="رابط الموقع" Margin="0,10,0,3"/>
                                    <TextBox x:Name="WebsiteTextBox" Height="36" Text="aldawish.sa"/>

                                    <TextBlock Text="الكابشن" Margin="0,10,0,3"/>
                                    <TextBox x:Name="CaptionTextBox" Height="110" TextWrapping="Wrap" AcceptsReturn="True" Text="متوفر الآن في متجر الدويش. اطلبه من الموقع."/>

                                    <WrapPanel Margin="0,8,0,0">
                                        <CheckBox x:Name="InstagramCheckBox" Content="Instagram" IsChecked="True" Margin="6"/>
                                        <CheckBox x:Name="TikTokCheckBox" Content="TikTok" IsChecked="True" Margin="6"/>
                                        <CheckBox x:Name="SnapchatCheckBox" Content="Snapchat" IsChecked="True" Margin="6"/>
                                    </WrapPanel>

                                    <TextBlock Text="وضع TikTok" Margin="0,10,0,3"/>
                                    <ComboBox x:Name="TikTokModeComboBox" SelectedIndex="0">
                                        <ComboBoxItem Content="صورة فقط" Tag="ImageOnly"/>
                                        <ComboBoxItem Content="صورة أولًا ثم فيديو صامت احتياطي" Tag="ImageFirstSilentVideoFallback"/>
                                        <ComboBoxItem Content="فيديو صامت فقط" Tag="SilentVideoOnly"/>
                                    </ComboBox>

                                    <Button Style="{StaticResource PrimaryButton}" Content="فحص واعتماد وإرسال للمزامنة" Height="44" Margin="0,14,0,0" Click="CreateJob_Click"/>
                                    <Button Content="توليد كابشنات آمنة" Height="42" Click="GenerateCaptionVariants_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,10,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="مركز الاعتماد والمنشورات" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock x:Name="StatusText" Text="اختر مجلد DawishSync داخل OneDrive/Drive/Syncthing." Foreground="{StaticResource DawishMuted}" Margin="0,4,0,10"/>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1.1*"/>
                                        <RowDefinition Height="0.9*"/>
                                        <RowDefinition Height="1.4*"/>
                                    </Grid.RowDefinitions>
                                    <GroupBox Header="مركز الاعتماد" Margin="0,6">
                                        <ListBox x:Name="ApprovalListBox"/>
                                    </GroupBox>
                                    <GroupBox Grid.Row="1" Header="الكابشنات الآمنة" Margin="0,6">
                                        <ListBox x:Name="CaptionVariantsListBox" SelectionChanged="CaptionVariantsListBox_SelectionChanged"/>
                                    </GroupBox>
                                    <GroupBox Grid.Row="2" Header="المنشورات في مجلد المزامنة" Margin="0,6">
                                        <ListBox x:Name="JobsListBox" SelectionChanged="JobsListBox_SelectionChanged"/>
                                    </GroupBox>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="#111A16" CornerRadius="32" Padding="16">
                            <StackPanel>
                                <TextBlock Text="معاينة الجوال" Foreground="White" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center"/>
                                <Border Background="White" CornerRadius="25" Margin="0,14,0,0" Padding="16" Height="650">
                                    <StackPanel>
                                        <TextBlock x:Name="PreviewPlatformText" Text="Instagram / TikTok / Snapchat" Foreground="#666" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <Border Background="#EEE" Height="335" Margin="0,12" CornerRadius="18">
                                            <TextBlock x:Name="PreviewImageText" Text="صورة المنشور" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#777"/>
                                        </Border>
                                        <TextBlock x:Name="PreviewCaptionText" Text="الكابشن يظهر هنا" TextWrapping="Wrap"/>
                                        <Border Background="#F7F1E8" CornerRadius="12" Padding="10" Margin="0,10,0,0">
                                            <StackPanel>
                                                <TextBlock Text="TikTok: صورة فقط وبدون صوت" Foreground="#8A6B3F"/>
                                                <TextBlock Text="Snapchat: صورة فقط" Foreground="#8A6B3F"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Bulk">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="430"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="تعديل جماعي" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="حدد صور كثيرة، طبّق نفس الإعدادات، وكل صورة تنزل كمنشور مستقل." Foreground="{StaticResource DawishMuted}" TextWrapping="Wrap" Margin="0,4,0,12"/>
                                    <Button Style="{StaticResource PrimaryButton}" Content="اختيار صور متعددة" Height="44" Click="ChooseBulkImages_Click"/>
                                    <TextBlock x:Name="BulkCountText" Text="لم يتم اختيار صور" Foreground="{StaticResource DawishMuted}"/>

                                    <TextBlock Text="عنوان المجموعة" Margin="0,10,0,3"/>
                                    <TextBox x:Name="BulkTitleTextBox" Text="منشور" Height="36"/>
                                    <TextBlock Text="الكابشن المشترك" Margin="0,10,0,3"/>
                                    <TextBox x:Name="BulkCaptionTextBox" Height="95" TextWrapping="Wrap" AcceptsReturn="True" Text="متوفر الآن في متجر الدويش. اطلبه من الموقع."/>
                                    <TextBlock Text="الحملة" Margin="0,10,0,3"/>
                                    <TextBox x:Name="BulkCampaignTextBox" Height="36" Text="حملة جديدة"/>

                                    <TextBlock Text="بداية الجدولة" Margin="0,10,0,3"/>
                                    <DatePicker x:Name="BulkStartDatePicker"/>
                                    <TextBox x:Name="BulkStartTimeTextBox" Height="36" Text="19:00" Margin="0,6,0,0"/>
                                    <TextBlock Text="عدد المنشورات في اليوم" Margin="0,10,0,3"/>
                                    <TextBox x:Name="BulkPostsPerDayTextBox" Height="36" Text="1"/>
                                    <TextBlock Text="الدقائق بين المنشورات" Margin="0,10,0,3"/>
                                    <TextBox x:Name="BulkMinutesBetweenTextBox" Height="36" Text="120"/>
                                    <CheckBox x:Name="BulkSkipFridayCheckBox" Content="تخطي الجمعة" Margin="0,8"/>

                                    <WrapPanel>
                                        <CheckBox x:Name="BulkInstagramCheckBox" Content="Instagram" IsChecked="True" Margin="6"/>
                                        <CheckBox x:Name="BulkTikTokCheckBox" Content="TikTok" IsChecked="True" Margin="6"/>
                                        <CheckBox x:Name="BulkSnapchatCheckBox" Content="Snapchat" IsChecked="True" Margin="6"/>
                                    </WrapPanel>
                                    <ComboBox x:Name="BulkTikTokModeComboBox" SelectedIndex="0">
                                        <ComboBoxItem Content="TikTok صورة فقط" Tag="ImageOnly"/>
                                        <ComboBoxItem Content="صورة أولًا ثم فيديو صامت احتياطي" Tag="ImageFirstSilentVideoFallback"/>
                                        <ComboBoxItem Content="فيديو صامت فقط" Tag="SilentVideoOnly"/>
                                    </ComboBox>
                                    <Button Content="معاينة التوزيع" Height="42" Click="PreviewBulk_Click"/>
                                    <Button Style="{StaticResource PrimaryButton}" Content="اعتماد كل الصور كمنشورات منفصلة" Height="44" Click="CreateBulkJobs_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="ملخص التعديل الجماعي" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="سيظهر هنا توزيع كل صورة كتاريخ ووقت ومنصة وحالة TikTok." Foreground="{StaticResource DawishMuted}"/>
                                </StackPanel>
                                <ListBox x:Name="BulkPreviewListBox" Grid.Row="1" Margin="0,14,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="ApprovalCenter">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="مركز الاعتماد" FontSize="24" FontWeight="Bold"/>
                                <TextBlock Text="آخر فحص لمنشور واحد أو مجموعة صور. لا يتم الإرسال للمزامنة إلا بعد مرور الفحص." Foreground="{StaticResource DawishMuted}" Margin="0,4,0,10"/>
                                <ListBox x:Name="ApprovalCenterMirrorListBox" Height="560"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Grid.Column="1">
                            <StackPanel>
                                <TextBlock Text="قواعد الاعتماد" FontSize="24" FontWeight="Bold"/>
                                <TextBlock Text="✅ الصورة موجودة" FontSize="18" Margin="0,14,0,0"/>
                                <TextBlock Text="✅ الكابشن موجود وآمن" FontSize="18"/>
                                <TextBlock Text="✅ لا توجد ادعاءات طبية" FontSize="18"/>
                                <TextBlock Text="✅ TikTok صورة فقط وبدون صوت" FontSize="18"/>
                                <TextBlock Text="✅ Snapchat صورة فقط" FontSize="18"/>
                                <TextBlock Text="✅ READY.flag لا يكتب إلا بعد اكتمال الملفات" FontSize="18"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Preview">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#111A16" CornerRadius="34" Padding="16" Margin="8">
                            <StackPanel>
                                <TextBlock Text="Instagram" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <Border Background="White" CornerRadius="24" Padding="16" Height="620" Margin="0,14,0,0">
                                    <StackPanel>
                                        <TextBlock Text="@attarat_aldawish" FontWeight="Bold"/>
                                        <Border Background="#EEE" Height="360" CornerRadius="18" Margin="0,14"><TextBlock Text="الصورة" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#777"/></Border>
                                        <TextBlock x:Name="InstagramPreviewCaptionText" Text="الكابشن" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#050505" CornerRadius="34" Padding="16" Margin="8">
                            <StackPanel>
                                <TextBlock Text="TikTok" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <Border Background="#151515" CornerRadius="24" Padding="16" Height="620" Margin="0,14,0,0">
                                    <StackPanel>
                                        <Border Background="#222" Height="410" CornerRadius="18"><TextBlock Text="صورة فقط" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White"/></Border>
                                        <TextBlock x:Name="TikTokPreviewCaptionText" Text="بدون صوت — بدون أغاني" Foreground="White" TextWrapping="Wrap" Margin="0,12,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#1A211C" CornerRadius="34" Padding="16" Margin="8">
                            <StackPanel>
                                <TextBlock Text="Snapchat" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <Border Background="#FFF7D6" CornerRadius="24" Padding="16" Height="620" Margin="0,14,0,0">
                                    <StackPanel>
                                        <Border Background="#F1E4B3" Height="430" CornerRadius="18"><TextBlock Text="صورة فقط" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#4A3B17"/></Border>
                                        <TextBlock x:Name="SnapchatPreviewCaptionText" Text="سناب صورة فقط" TextWrapping="Wrap" Margin="0,12,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Device">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="وضع هذا الجهاز" FontSize="24" FontWeight="Bold"/>
                                <TextBlock Text="نفس البرنامج يشتغل على لابتوبك وعلى جهاز المحل. على جهاز المحل شغل محطة النشر." TextWrapping="Wrap" Foreground="{StaticResource DawishMuted}" Margin="0,4,0,10"/>
                                <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft" Margin="0,0,0,10">
                                    <RadioButton x:Name="ManagerModeRadio" Content="جهاز الإدارة" IsChecked="True" Margin="8" Checked="DeviceMode_Checked"/>
                                    <RadioButton x:Name="PublisherModeRadio" Content="جهاز المحل" Margin="8" Checked="DeviceMode_Checked"/>
                                </StackPanel>
                                <WrapPanel>
                                    <Button Style="{StaticResource PrimaryButton}" Content="تشغيل محطة النشر على هذا الجهاز" Click="StartLocalPublisher_Click" Height="44" MinWidth="230"/>
                                    <Button Content="إيقاف محطة النشر" Click="StopLocalPublisher_Click" Height="44" MinWidth="160"/>
                                    <Button Content="فحص الآن" Click="RunLocalPublisherOnce_Click" Height="44" MinWidth="120"/>
                                </WrapPanel>
                                <TextBlock x:Name="LocalPublisherStatusText" Text="محطة النشر: متوقفة" Foreground="{StaticResource DawishInk}" FontWeight="Bold" Margin="0,10,0,10" TextWrapping="Wrap"/>
                                <Separator Margin="0,8"/>
                                <TextBlock Text="مراقبة الأجهزة" FontSize="20" FontWeight="Bold"/>
                                <Button Content="قراءة Heartbeat" Click="RefreshHeartbeat_Click" Height="42"/>
                                <ListBox x:Name="HeartbeatListBox" Height="360" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="حالات النشر" FontSize="24" FontWeight="Bold"/>
                                <Button Content="قراءة الحالات" Click="RefreshStatuses_Click" Height="42"/>
                                <WrapPanel Margin="0,8,0,0">
                                    <Button Content="تعليم المحدد تم" Click="MarkSelectedDone_Click" Height="38" MinWidth="140"/>
                                    <Button Style="{StaticResource DangerButton}" Content="تعليم المحدد فشل" Click="MarkSelectedFailed_Click" Height="38" MinWidth="140"/>
                                </WrapPanel>
                                <ListBox x:Name="StatusesListBox" Height="500" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Archive">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="الأرشيف والسجل" FontSize="24" FontWeight="Bold"/>
                            <TextBlock Text="هذه الصفحة تجمع الحالات والسجلات والأخطاء. حاليًا اقرأ الحالات من صفحة جهاز المحل والمزامنة، والدفعة القادمة تضيف فلترة مفصلة." Foreground="{StaticResource DawishMuted}" TextWrapping="Wrap" Margin="0,6,0,14"/>
                            <ListBox x:Name="ArchivePlaceholderListBox" Height="560">
                                <ListBoxItem Content="تم تجهيز الهيكل للأرشيف الذكي."/>
                                <ListBoxItem Content="لاحقًا: فلترة حسب المنصة، التاريخ، الحالة، والتكرار."/>
                                <ListBoxItem Content="لاحقًا: فتح screenshots والأخطاء من داخل البرنامج."/>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </TabItem>

                <TabItem Header="Settings">
                    <Border Style="{StaticResource Card}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="الإعدادات" FontSize="24" FontWeight="Bold"/>
                                <TextBlock Text="مجلد المزامنة بين لابتوبك وجهاز المحل" Margin="0,14,0,4"/>
                                <DockPanel>
                                    <Button Content="اختيار" Width="110" DockPanel.Dock="Left" Click="ChooseFolder_Click"/>
                                    <TextBox x:Name="SyncFolderTextBox" Height="40" VerticalContentAlignment="Center"/>
                                </DockPanel>
                                <TextBlock Text="الإعدادات الثابتة" FontSize="20" FontWeight="Bold" Margin="0,18,0,8"/>
                                <TextBlock Text="• بدون API نهائيًا" FontSize="18"/>
                                <TextBlock Text="• TikTok صورة فقط افتراضيًا وبدون صوت" FontSize="18"/>
                                <TextBlock Text="• Snapchat صورة فقط" FontSize="18"/>
                                <TextBlock Text="• منع الكلام الطبي صارم" FontSize="18"/>
                                <TextBlock Text="• جهاز المحل لا ينشر Job إلا بعد READY.flag" FontSize="18"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <TabItem Header="Onboarding">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource Card}" Margin="8" Background="#FFF9EE">
                                <StackPanel>
                                    <TextBlock Text="أول تشغيل" FontSize="30" FontWeight="Bold"/>
                                    <TextBlock Text="اتبع هذه الخطوات مرة واحدة على جهازك وعلى جهاز المحل. نفس البرنامج يعمل في الوضعين." Foreground="{StaticResource DawishMuted}" FontSize="16" TextWrapping="Wrap" Margin="0,6,0,18"/>
                                    <UniformGrid Columns="4">
                                        <Border Style="{StaticResource MiniCard}" Margin="6">
                                            <StackPanel>
                                                <TextBlock Text="1" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DawishAccent}"/>
                                                <TextBlock Text="اختر DawishSync" FontWeight="Bold"/>
                                                <TextBlock Text="يفضل داخل OneDrive أو Google Drive. هذا هو جسر الجهازين بدون API." Foreground="{StaticResource DawishMuted}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MiniCard}" Margin="6">
                                            <StackPanel>
                                                <TextBlock Text="2" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DawishAccent}"/>
                                                <TextBlock Text="حدد وضع الجهاز" FontWeight="Bold"/>
                                                <TextBlock Text="لابتوبك = جهاز الإدارة. جهاز المحل = محطة النشر." Foreground="{StaticResource DawishMuted}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MiniCard}" Margin="6">
                                            <StackPanel>
                                                <TextBlock Text="3" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DawishAccent}"/>
                                                <TextBlock Text="جهز المنشورات" FontWeight="Bold"/>
                                                <TextBlock Text="ارفع الصور، اكتب الكابشن، اختر المنصات، ثم اعتمد." Foreground="{StaticResource DawishMuted}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MiniCard}" Margin="6">
                                            <StackPanel>
                                                <TextBlock Text="4" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DawishAccent}"/>
                                                <TextBlock Text="شغل جهاز المحل" FontWeight="Bold"/>
                                                <TextBlock Text="محطة النشر تراقب المجلد وترجع الحالة. TikTok صورة فقط، Snapchat صورة فقط." Foreground="{StaticResource DawishMuted}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                    <WrapPanel Margin="0,16,0,0">
                                        <Button Style="{StaticResource PrimaryButton}" Content="اختيار مجلد المزامنة" Click="ChooseFolder_Click" MinWidth="180"/>
                                        <Button Content="فتح صفحة جهاز المحل" Click="ShowDevice_Click" MinWidth="170"/>
                                        <Button Content="إنشاء منشور" Click="ShowPosts_Click" MinWidth="140"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="8">
                                <StackPanel>
                                    <TextBlock Text="قواعد لا تتغير" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="• لا نستخدم API لأي منصة.
• TikTok صورة فقط افتراضيًا وبدون صوت وبدون أغاني.
• Snapchat صورة فقط.
• لا يعتمد أي كابشن فيه ادعاء طبي أو علاجي.
• كل صورة في التعديل الجماعي تتحول إلى منشور مستقل." FontSize="17" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
