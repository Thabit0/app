<Window x:Class="DawishContentStudio.Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dawish Content Studio Manager" Height="830" Width="1320"
        FlowDirection="RightToLeft" WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource DawishBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource DawishBrown}" Padding="18">
            <StackPanel>
                <TextBlock Text="Dawish" Foreground="White" FontSize="30" FontWeight="Bold"/>
                <TextBlock Text="Content Studio" Foreground="#F4D8A8" FontSize="17" Margin="0,0,0,22"/>
                <Button Content="تحديث البيانات" Click="Refresh_Click" Height="42"/>
                <Button Content="اختيار مجلد المزامنة" Click="ChooseFolder_Click" Height="42"/>
                <Separator Margin="0,16"/>
                <TextBlock Text="القواعد الثابتة" Foreground="#F4D8A8" FontWeight="Bold"/>
                <TextBlock Text="بدون API نهائيًا. تيك توك صورة أولًا وبدون صوت. سناب صورة فقط. منع الكلام الطبي." Foreground="White" TextWrapping="Wrap" Margin="0,8"/>
                <Separator Margin="0,16"/>
                <TextBlock x:Name="HeartbeatText" Foreground="White" TextWrapping="Wrap" Text="جهاز المحل: غير معروف"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="White" CornerRadius="18" Padding="16" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="مجلد المزامنة بين لابتوبك وجهاز المحل" FontSize="22" FontWeight="Bold" Foreground="#3D2617"/>
                    <DockPanel Margin="0,10,0,0">
                        <Button Content="اختيار" Width="100" DockPanel.Dock="Left" Click="ChooseFolder_Click"/>
                        <TextBox x:Name="SyncFolderTextBox" Height="38" VerticalContentAlignment="Center"/>
                    </DockPanel>
                    <TextBlock x:Name="StatusText" Text="اختر مجلد DawishSync داخل OneDrive/Drive/Syncthing." Foreground="#6A5B50" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <TabControl Grid.Row="1">
                <TabItem Header="منشور واحد">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="430"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="White" CornerRadius="16" Padding="16" Margin="0,0,10,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="منشور جديد" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="العنوان" Margin="0,10,0,3"/>
                                <TextBox x:Name="TitleTextBox" Height="34" Text="منشور جديد"/>
                                <TextBlock Text="الصورة" Margin="0,10,0,3"/>
                                <TextBox x:Name="ImagePathTextBox" Height="34" Text="اختر صورة" IsReadOnly="True"/>
                                <Button Content="اختيار صورة" Click="ChooseImage_Click"/>
                                <TextBlock Text="تاريخ ووقت النشر" Margin="0,10,0,3"/>
                                <DatePicker x:Name="ScheduleDatePicker"/>
                                <TextBox x:Name="ScheduleTimeTextBox" Height="34" Text="19:00" Margin="0,6,0,0"/>
                                <TextBlock Text="رابط الموقع" Margin="0,10,0,3"/>
                                <TextBox x:Name="WebsiteTextBox" Height="34" Text="aldawish.sa"/>
                                <TextBlock Text="الكابشن" Margin="0,10,0,3"/>
                                <TextBox x:Name="CaptionTextBox" Height="95" TextWrapping="Wrap" AcceptsReturn="True" Text="متوفر الآن في متجر الدويش. اطلبه من الموقع."/>
                                <WrapPanel Margin="0,8,0,0">
                                    <CheckBox x:Name="InstagramCheckBox" Content="Instagram" IsChecked="True" Margin="4"/>
                                    <CheckBox x:Name="TikTokCheckBox" Content="TikTok" IsChecked="True" Margin="4"/>
                                    <CheckBox x:Name="SnapchatCheckBox" Content="Snapchat" IsChecked="True" Margin="4"/>
                                </WrapPanel>
                                <TextBlock Text="وضع TikTok" Margin="0,10,0,3"/>
                                <ComboBox x:Name="TikTokModeComboBox" SelectedIndex="0">
                                    <ComboBoxItem Content="صورة فقط" Tag="ImageOnly"/>
                                    <ComboBoxItem Content="صورة أولًا ثم فيديو صامت احتياطي" Tag="ImageFirstSilentVideoFallback"/>
                                    <ComboBoxItem Content="فيديو صامت فقط" Tag="SilentVideoOnly"/>
                                </ComboBox>
                                <Button Content="فحص واعتماد وإرسال للمزامنة" Height="42" Margin="0,12,0,0" Click="CreateJob_Click"/>
                                <Button Content="توليد كابشنات آمنة" Height="42" Click="GenerateCaptionVariants_Click"/>
                            </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="16" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="مركز الاعتماد" FontSize="20" FontWeight="Bold"/>
                                <ListBox x:Name="ApprovalListBox" Margin="0,10,0,0" Height="230"/>
                                <TextBlock Text="الكابشنات الآمنة" FontSize="18" FontWeight="Bold" Margin="0,14,0,6"/>
                                <ListBox x:Name="CaptionVariantsListBox" Height="150" SelectionChanged="CaptionVariantsListBox_SelectionChanged"/>
                                <TextBlock Text="المنشورات في مجلد المزامنة" FontSize="18" FontWeight="Bold" Margin="0,14,0,6"/>
                                <ListBox x:Name="JobsListBox" Height="220" SelectionChanged="JobsListBox_SelectionChanged"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#111" CornerRadius="28" Padding="16">
                            <StackPanel>
                                <TextBlock Text="معاينة الجوال" Foreground="White" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
                                <Border Background="White" CornerRadius="22" Margin="0,14,0,0" Padding="14" Height="610">
                                    <StackPanel>
                                        <TextBlock x:Name="PreviewPlatformText" Text="Instagram / TikTok / Snapchat" Foreground="#666" FontWeight="Bold"/>
                                        <Border Background="#EEE" Height="310" Margin="0,12" CornerRadius="14">
                                            <TextBlock x:Name="PreviewImageText" Text="صورة المنشور" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#777"/>
                                        </Border>
                                        <TextBlock x:Name="PreviewCaptionText" Text="الكابشن يظهر هنا" TextWrapping="Wrap"/>
                                        <TextBlock Text="TikTok: صورة فقط وبدون صوت" Foreground="#8A6B3F" Margin="0,8,0,0"/>
                                        <TextBlock Text="Snapchat: صورة فقط" Foreground="#8A6B3F"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="تعديل جماعي">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="430"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="White" CornerRadius="16" Padding="16" Margin="0,0,10,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="تحديد صور كثيرة" FontSize="20" FontWeight="Bold"/>
                                <Button Content="اختيار صور متعددة" Height="42" Click="ChooseBulkImages_Click"/>
                                <TextBlock x:Name="BulkCountText" Text="لم يتم اختيار صور" Foreground="#6A5B50"/>
                                <TextBlock Text="عنوان المجموعة" Margin="0,10,0,3"/>
                                <TextBox x:Name="BulkTitleTextBox" Text="منشور" Height="34"/>
                                <TextBlock Text="الكابشن المشترك" Margin="0,10,0,3"/>
                                <TextBox x:Name="BulkCaptionTextBox" Height="90" TextWrapping="Wrap" AcceptsReturn="True" Text="متوفر الآن في متجر الدويش. اطلبه من الموقع."/>
                                <TextBlock Text="الحملة" Margin="0,10,0,3"/>
                                <TextBox x:Name="BulkCampaignTextBox" Height="34" Text="حملة جديدة"/>
                                <TextBlock Text="بداية الجدولة" Margin="0,10,0,3"/>
                                <DatePicker x:Name="BulkStartDatePicker"/>
                                <TextBox x:Name="BulkStartTimeTextBox" Height="34" Text="19:00" Margin="0,6,0,0"/>
                                <TextBlock Text="عدد المنشورات في اليوم" Margin="0,10,0,3"/>
                                <TextBox x:Name="BulkPostsPerDayTextBox" Height="34" Text="1"/>
                                <TextBlock Text="الدقائق بين المنشورات لو أكثر من واحد باليوم" Margin="0,10,0,3"/>
                                <TextBox x:Name="BulkMinutesBetweenTextBox" Height="34" Text="120"/>
                                <CheckBox x:Name="BulkSkipFridayCheckBox" Content="تخطي الجمعة" Margin="0,8"/>
                                <WrapPanel>
                                    <CheckBox x:Name="BulkInstagramCheckBox" Content="Instagram" IsChecked="True" Margin="4"/>
                                    <CheckBox x:Name="BulkTikTokCheckBox" Content="TikTok" IsChecked="True" Margin="4"/>
                                    <CheckBox x:Name="BulkSnapchatCheckBox" Content="Snapchat" IsChecked="True" Margin="4"/>
                                </WrapPanel>
                                <ComboBox x:Name="BulkTikTokModeComboBox" SelectedIndex="0">
                                    <ComboBoxItem Content="TikTok صورة فقط" Tag="ImageOnly"/>
                                    <ComboBoxItem Content="صورة أولًا ثم فيديو صامت احتياطي" Tag="ImageFirstSilentVideoFallback"/>
                                    <ComboBoxItem Content="فيديو صامت فقط" Tag="SilentVideoOnly"/>
                                </ComboBox>
                                <Button Content="معاينة التوزيع" Height="42" Click="PreviewBulk_Click"/>
                                <Button Content="اعتماد كل الصور كمنشورات منفصلة" Height="42" Click="CreateBulkJobs_Click"/>
                            </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="ملخص التعديل الجماعي: كل صورة ستنزل كمنشور مستقل" FontSize="20" FontWeight="Bold"/>
                                <ListBox x:Name="BulkPreviewListBox" Grid.Row="1" Margin="0,12,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="جهاز المحل والمراقبة">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="White" CornerRadius="16" Padding="16" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="حالة جهاز المحل" FontSize="20" FontWeight="Bold"/>
                                <Button Content="قراءة Heartbeat" Click="RefreshHeartbeat_Click" Height="42"/>
                                <ListBox x:Name="HeartbeatListBox" Height="500" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="16">
                            <StackPanel>
                                <TextBlock Text="حالات النشر" FontSize="20" FontWeight="Bold"/>
                                <Button Content="قراءة الحالات" Click="RefreshStatuses_Click" Height="42"/>
                                <WrapPanel Margin="0,8,0,0">
                                    <Button Content="تعليم المحدد تم" Click="MarkSelectedDone_Click" Height="36" MinWidth="130" Margin="4"/>
                                    <Button Content="تعليم المحدد فشل" Click="MarkSelectedFailed_Click" Height="36" MinWidth="130" Margin="4"/>
                                </WrapPanel>
                                <ListBox x:Name="StatusesListBox" Height="450" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
