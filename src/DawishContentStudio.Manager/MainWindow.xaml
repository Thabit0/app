<Window x:Class="DawishContentStudio.Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dawish Content Studio v2.0" Height="900" Width="1440"
        MinHeight="740" MinWidth="1120" FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen" Background="{StaticResource Bg}"
        Icon="Assets/AppIcon.ico" PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <TabControl x:Name="RootTabs" Background="Transparent" BorderThickness="0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem"><Setter Property="Visibility" Value="Collapsed"/></Style>
            </TabControl.ItemContainerStyle>

            <!-- First link -->
            <TabItem>
                <Grid>
                    <Border Width="660" Padding="34" CornerRadius="28" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel>
                            <Image Source="Assets/AppIcon.png" Width="110" Height="110"/>
                            <TextBlock Text="ربط الجهاز لأول مرة" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,12,0,4"/>
                            <TextBlock Text="أدخل بيانات Cloudflare مرة واحدة، وبعدها تستخدم رمز الدخول فقط." Foreground="{StaticResource Muted}" TextAlignment="Center" TextWrapping="Wrap" FontSize="16"/>
                            <TextBlock Style="{StaticResource SmallLabel}" Text="نوع الجهاز" Margin="0,24,0,4"/>
                            <UniformGrid Columns="2">
                                <RadioButton x:Name="SetupAdminRadio" Content="جهاز المالك" IsChecked="True" FontSize="17" Margin="8"/>
                                <RadioButton x:Name="SetupShopRadio" Content="جهاز المحل" FontSize="17" Margin="8"/>
                            </UniformGrid>
                            <TextBlock Style="{StaticResource SmallLabel}" Text="رابط Worker"/>
                            <TextBox x:Name="SetupWorkerUrl" FlowDirection="LeftToRight" TextAlignment="Left" Text="https://dawish-content-api.thabit1919.workers.dev"/>
                            <TextBlock Style="{StaticResource SmallLabel}" Text="Token"/>
                            <PasswordBox x:Name="SetupToken" FlowDirection="LeftToRight"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="ربط الجهاز" FontSize="17" Click="LinkDevice_Click"/>
                            <TextBlock x:Name="SetupStatus" Foreground="{StaticResource Muted}" TextAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Daily PIN login -->
            <TabItem>
                <Grid>
                    <Border Width="510" Padding="40" CornerRadius="30" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel>
                            <Image Source="Assets/AppIcon.png" Width="120" Height="120"/>
                            <TextBlock Text="عطارة الدويش" FontSize="31" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="Dawish Content Studio" Foreground="{StaticResource Muted}" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="أدخل رمز الدخول" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,28,0,8"/>
                            <PasswordBox x:Name="PinPasswordBox" MaxLength="6" FontSize="28" HorizontalContentAlignment="Center" FlowDirection="LeftToRight" KeyDown="PinPasswordBox_KeyDown"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="دخول" FontSize="18" Click="Login_Click"/>
                            <TextBlock x:Name="LoginErrorText" Foreground="{StaticResource Danger}" TextAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Manager workspace -->
            <TabItem>
                <Grid Margin="16">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Border Style="{StaticResource Card}" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="Assets/AppIcon.png" Width="54" Height="54" Margin="0,0,12,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="لوحة توزيع المنشورات" FontSize="27" FontWeight="Bold"/>
                                    <TextBlock x:Name="ManagerConnectionText" Text="جهاز المالك" Foreground="{StaticResource Muted}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource PrimaryButton}" Content="📁 استيراد مجلد" Click="ChooseFolder_Click"/>
                                <Button Content="＋ إضافة صور" Click="AddImages_Click"/>
                                <Button Content="🗑 حذف المحدد" Click="DeleteSelected_Click"/>
                                <Button Content="☑ تحديد الكل" Click="SelectAll_Click"/>
                                <Button Content="○ تحديد غير المجدول" Click="SelectUnscheduled_Click"/>
                                <Button Content="إلغاء التحديد" Click="ClearSelection_Click"/>
                                <Button Content="خروج" Click="Logout_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="ProgressTitle" Text="استورد مجلد الصور للبدء" FontSize="18" FontWeight="Bold"/>
                                <ProgressBar x:Name="ScheduleProgress" Height="12" Minimum="0" Maximum="100" Value="0" Margin="0,8,0,0"/>
                                <TextBlock x:Name="ProgressHint" Text="كل صورة ستصبح منشورًا مستقلًا" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="📅 جدولة المحدد" Click="OpenSchedulePanel_Click"/>
                                <Button Content="⚡ توزيع تلقائي" Click="OpenAutoPanel_Click"/>
                                <Button Style="{StaticResource PrimaryButton}" Content="✓ إنهاء ورفع" Click="FinishUpload_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="340"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Padding="10">
                            <ListBox x:Name="ImagesListBox" ItemsSource="{Binding Images}" SelectionMode="Multiple" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel IsItemsHost="True"/></ItemsPanelTemplate></ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="190" Height="245" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="17" Margin="6" Padding="7">
                                            <Grid>
                                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="168"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2"/>
                                                <Border Grid.Row="1" CornerRadius="12" ClipToBounds="True" Background="#EFE9DD"><Image Source="{Binding Path}" Stretch="UniformToFill"/></Border>
                                                <StackPanel Grid.Row="2" Margin="3,7,3,0">
                                                    <TextBlock Text="{Binding StatusText}" FontWeight="Bold" Foreground="{StaticResource Green}"/>
                                                    <TextBlock Text="{Binding ScheduleDateText}" FontSize="12" Foreground="{StaticResource Muted}"/>
                                                    <TextBlock Text="{Binding ScheduleTimeText}" FontSize="12" Foreground="{StaticResource Muted}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="18">
                            <StackPanel>
                                <TextBlock Text="الجدولة" FontSize="24" FontWeight="Bold"/>
                                <TextBlock x:Name="SelectedCountText" Text="لم تحدد صورًا" Foreground="{StaticResource Muted}" Margin="0,3,0,14"/>
                                <TextBlock Style="{StaticResource SmallLabel}" Text="التاريخ"/>
                                <DatePicker x:Name="ScheduleDatePicker"/>
                                <TextBlock Style="{StaticResource SmallLabel}" Text="الوقت"/>
                                <UniformGrid Columns="3">
                                    <ComboBox x:Name="HourComboBox"/>
                                    <ComboBox x:Name="MinuteComboBox"/>
                                    <ComboBox x:Name="AmPmComboBox"><ComboBoxItem Content="ص"/><ComboBoxItem Content="م" IsSelected="True"/></ComboBox>
                                </UniformGrid>
                                <Button Style="{StaticResource PrimaryButton}" Content="تطبيق على المحدد" Click="ApplySchedule_Click"/>
                                <Separator Margin="0,14"/>
                                <TextBlock Text="التوزيع التلقائي" FontSize="19" FontWeight="Bold"/>
                                <TextBlock Style="{StaticResource SmallLabel}" Text="عدد الصور يوميًا"/>
                                <ComboBox x:Name="DailyCountComboBox"/>
                                <Button Content="وزّع غير المجدول تلقائيًا" Click="ApplyAutoSchedule_Click"/>
                                <Separator Margin="0,14"/>
                                <TextBlock Text="الإعدادات الجاهزة" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Instagram: مدينة الزلفي" Foreground="{StaticResource Muted}" Margin="0,7,0,0"/>
                                <TextBlock Text="TikTok: عطارة الدويش — صورة بلا صوت" Foreground="{StaticResource Muted}" TextWrapping="Wrap"/>
                                <TextBlock Text="Snapchat: الصورة الأصلية فقط — بلا موقع" Foreground="{StaticResource Muted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3" Style="{StaticResource Card}" Padding="12">
                        <TextBlock x:Name="ManagerStatusText" Text="جاهز" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Shop station -->
            <TabItem>
                <Grid Margin="18">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Style="{StaticResource Card}">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="جهاز المحل" FontSize="29" FontWeight="Bold"/><TextBlock x:Name="ShopConnectionText" Text="محطة النشر" Foreground="{StaticResource Muted}"/></StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"><Button Style="{StaticResource PrimaryButton}" Content="تشغيل المحطة" Click="StartShopStation_Click"/><Button Content="إيقاف" Click="StopShopStation_Click"/><Button Content="تحديث" Click="RefreshDuePosts_Click"/><Button Content="خروج" Click="Logout_Click"/></StackPanel>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="420"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="حسابات النشر" FontSize="24" FontWeight="Bold"/>
                                <TextBlock Text="سجّل الدخول مرة واحدة في المتصفح على جهاز المحل؛ يحتفظ المتصفح بالجلسة محليًا." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,5,0,12"/>
                                <Button Content="Instagram — تسجيل الدخول" Click="OpenInstagram_Click"/>
                                <Button Content="TikTok — تسجيل الدخول" Click="OpenTikTok_Click"/>
                                <Button Content="Snapchat — تسجيل الدخول" Click="OpenSnapchat_Click"/>
                                <Button Style="{StaticResource PrimaryButton}" Content="اختبار الحسابات" Click="TestAccounts_Click"/>
                                <TextBlock x:Name="AccountsStatusText" Text="لم يتم الاختبار" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            </StackPanel></Border>
                            <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="حالة المحطة" FontSize="22" FontWeight="Bold"/><TextBlock x:Name="ShopStationText" Text="متوقفة" FontSize="18" Margin="0,8,0,0"/><TextBlock Text="TikTok: صورة فقط بدون أغنية أو صوت" Foreground="{StaticResource Muted}" TextWrapping="Wrap"/><TextBlock Text="Snapchat: الصورة الأصلية فقط بدون موقع" Foreground="{StaticResource Muted}" TextWrapping="Wrap"/></StackPanel></Border>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource Card}"><StackPanel><TextBlock Text="المنشورات المستحقة" FontSize="25" FontWeight="Bold"/><ListBox x:Name="DuePostsListBox" Margin="0,12,0,0" FontSize="15"/></StackPanel></Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
