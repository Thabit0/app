<Window x:Class="DawishContentStudio.Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dawish Content Studio v1.0" Height="860" Width="1400"
        MinHeight="720" MinWidth="1120" FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen" Background="{StaticResource Bg}"
        Icon="Assets/AppIcon.ico" PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="230"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="1" Background="{StaticResource Dark}" Margin="14" CornerRadius="28" Padding="16">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel>
                    <Image Source="Assets/AppIcon.png" Width="88" Height="88" Stretch="Uniform"/>
                    <TextBlock Text="عطارة الدويش" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Content Studio" Foreground="#E8D2A8" HorizontalAlignment="Center"/>
                    <Border Background="#F4E7C4" CornerRadius="14" Padding="9" Margin="0,16,0,0">
                        <TextBlock x:Name="RoleBadgeText" Text="اختر الجهاز" Foreground="#17382B" FontWeight="Bold" TextAlignment="Center"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Row="1" Margin="0,24,0,0">
                    <Button x:Name="NavLogin" Style="{StaticResource NavButton}" Content="🔐  الدخول" Click="ShowLogin_Click"/>
                    <Button x:Name="NavWorkspace" Style="{StaticResource NavButton}" Content="📁  الصور والجدولة" Click="ShowWorkspace_Click"/>
                    <Button x:Name="NavShop" Style="{StaticResource NavButton}" Content="🏪  جهاز المحل" Click="ShowShop_Click"/>
                </StackPanel>
                <StackPanel Grid.Row="2">
                    <Separator Background="#557064"/>
                    <TextBlock x:Name="ConnectionStatusText" Text="Cloudflare: غير مفحوص" Foreground="White" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,0"/>
                    <TextBlock Text="كل صورة = منشور مستقل" Foreground="#D8E3DD" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="0" Margin="14,14,0,14">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="22" Padding="16" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="PageTitleText" Text="الدخول" FontSize="28" FontWeight="Bold"/>
                        <TextBlock x:Name="PageHintText" Text="اختر نوع الجهاز وأدخل الرمز مرة واحدة." Foreground="{StaticResource Muted}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="فحص الاتصال" Click="TestConnection_Click"/>
                        <Button Style="{StaticResource PrimaryButton}" Content="تحديث" Click="Refresh_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl x:Name="MainTabs" Grid.Row="1" Background="Transparent" BorderThickness="0">
                <TabControl.ItemContainerStyle><Style TargetType="TabItem"><Setter Property="Visibility" Value="Collapsed"/></Style></TabControl.ItemContainerStyle>

                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="940" HorizontalAlignment="Center">
                            <Border Style="{StaticResource Card}" Background="#FFF8E9">
                                <StackPanel>
                                    <TextBlock Text="دخول بسيط مرة واحدة" FontSize="30" FontWeight="Bold"/>
                                    <TextBlock Text="اختر جهاز المدير أو جهاز المحل، ثم ضع رابط Cloudflare والرمز الخاص به." Foreground="{StaticResource Muted}" FontSize="16" TextWrapping="Wrap" Margin="0,6,0,18"/>
                                    <UniformGrid Columns="2">
                                        <Button x:Name="AdminRoleButton" Style="{StaticResource PrimaryButton}" Content="👤 أنا المدير" Click="SetAdminRole_Click" FontSize="18" Padding="20"/>
                                        <Button x:Name="ShopRoleButton" Content="🏪 هذا جهاز المحل" Click="SetShopRole_Click" FontSize="18" Padding="20"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="الربط" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Style="{StaticResource SmallLabel}" Text="Worker URL"/>
                                    <TextBox x:Name="WorkerUrlTextBox" FlowDirection="LeftToRight" TextAlignment="Left"/>
                                    <TextBlock Style="{StaticResource SmallLabel}" Text="الرمز"/>
                                    <PasswordBox x:Name="TokenPasswordBox" FlowDirection="LeftToRight"/>
                                    <Button Style="{StaticResource PrimaryButton}" Content="حفظ وفحص" Click="TestConnection_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem>
                    <Grid AllowDrop="True" Drop="Workspace_Drop" DragOver="Workspace_DragOver">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="360"/></Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="14">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="الصور" FontSize="26" FontWeight="Bold"/>
                                            <TextBlock x:Name="ImageCountText" Text="اسحب مجلدًا هنا أو اختره. كل صورة تتحول إلى منشور مستقل." Foreground="{StaticResource Muted}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Style="{StaticResource PrimaryButton}" Content="📁 اختيار مجلد" Click="ChooseFolder_Click"/>
                                            <Button Content="🖼 إضافة صور" Click="ChooseImages_Click"/>
                                        </StackPanel>
                                    </Grid>
                                    <WrapPanel Margin="0,10,0,8">
                                        <Button Content="تحديد الكل  Ctrl+A" Click="SelectAll_Click"/>
                                        <Button Content="إلغاء التحديد" Click="ClearSelection_Click"/>
                                        <Button Style="{StaticResource DangerButton}" Content="حذف المحدد  Delete" Click="DeleteSelected_Click"/>
                                    </WrapPanel>
                                </StackPanel>

                                <ListBox x:Name="ImagesListBox" SelectionMode="Extended" SelectionChanged="ImagesListBox_SelectionChanged" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel IsItemsHost="True"/></ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="178" Height="226" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="14" Margin="6" Padding="7">
                                                <Grid>
                                                    <Grid.RowDefinitions><RowDefinition Height="150"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                                    <Border Background="#F0ECE3" CornerRadius="10" ClipToBounds="True"><Image Source="{Binding Path}" Stretch="UniformToFill"/></Border>
                                                    <TextBlock Grid.Row="1" Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="2,7,2,0" FlowDirection="LeftToRight"/>
                                                    <TextBlock Grid.Row="2" Text="{Binding Status}" Foreground="{StaticResource Green}" FontWeight="Bold" Margin="2,5,2,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock x:Name="EditTitleText" Text="إعدادات المنشورات" FontSize="23" FontWeight="Bold"/>
                                        <TextBlock x:Name="SelectionSummaryText" Text="حدد صورة أو عدة صور" Foreground="{StaticResource Muted}" Margin="0,4,0,10"/>
                                        <Border Height="180" Background="#F0ECE3" CornerRadius="14"><Image x:Name="SelectedImagePreview" Stretch="Uniform"/></Border>
                                        <TextBlock Style="{StaticResource SmallLabel}" Text="الكابشن الأساسي"/>
                                        <TextBox x:Name="CaptionTextBox" AcceptsReturn="True" Height="120" Text="متوفر الآن في عطارة الدويش." TextChanged="PostFields_Changed"/>
                                        <TextBlock Text="يُمنع أي ادعاء طبي أو علاجي." Foreground="#A34E41"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="المنصات واللوكيشن" FontSize="21" FontWeight="Bold"/>
                                        <WrapPanel Margin="0,8,0,6">
                                            <CheckBox x:Name="InstagramCheckBox" Content="Instagram" IsChecked="True" Margin="8" Checked="PostFields_Changed" Unchecked="PostFields_Changed"/>
                                            <CheckBox x:Name="TikTokCheckBox" Content="TikTok" IsChecked="True" Margin="8" Checked="PostFields_Changed" Unchecked="PostFields_Changed"/>
                                            <CheckBox x:Name="SnapchatCheckBox" Content="Snapchat" Margin="8" Checked="PostFields_Changed" Unchecked="PostFields_Changed"/>
                                        </WrapPanel>
                                        <TextBlock Style="{StaticResource SmallLabel}" Text="Instagram"/><TextBox x:Name="InstagramLocationTextBox" Text="مدينة الزلفي"/>
                                        <TextBlock Style="{StaticResource SmallLabel}" Text="TikTok"/><TextBox x:Name="TikTokLocationTextBox" Text="عطارة الدويش"/>
                                        <TextBlock Style="{StaticResource SmallLabel}" Text="Snapchat"/><TextBox x:Name="SnapchatLocationTextBox" Text="عطارة الدويش"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="الجدولة" FontSize="21" FontWeight="Bold"/>
                                        <DatePicker x:Name="ScheduleDatePicker"/>
                                        <WrapPanel>
                                            <ComboBox x:Name="HourComboBox" Width="72"/><ComboBox x:Name="MinuteComboBox" Width="72"/>
                                            <ComboBox x:Name="AmPmComboBox" Width="72"><ComboBoxItem Content="ص"/><ComboBoxItem Content="م" IsSelected="True"/></ComboBox>
                                        </WrapPanel>
                                        <TextBlock Style="{StaticResource SmallLabel}" Text="الفاصل بين كل منشور"/>
                                        <ComboBox x:Name="SpacingMinutesComboBox"><ComboBoxItem Content="30 دقيقة" Tag="30"/><ComboBoxItem Content="ساعة" Tag="60" IsSelected="True"/><ComboBoxItem Content="ساعتان" Tag="120"/><ComboBoxItem Content="يوم" Tag="1440"/></ComboBox>
                                        <Button Style="{StaticResource PrimaryButton}" Content="جدولة المحدد" Click="ScheduleSelected_Click"/>
                                        <Button Style="{StaticResource PrimaryButton}" Content="جدولة كل الصور" Click="ScheduleAllImages_Click"/>
                                        <TextBlock x:Name="UploadStatusText" TextWrapping="Wrap" FontWeight="Bold" Foreground="{StaticResource Green}" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="900" HorizontalAlignment="Center">
                            <Border Style="{StaticResource Card}" Background="#EDF5EF">
                                <StackPanel>
                                    <TextBlock Text="جهاز المحل" FontSize="30" FontWeight="Bold"/>
                                    <TextBlock x:Name="ShopStationText" Text="المحطة متوقفة" FontSize="18" Foreground="{StaticResource Muted}" Margin="0,8,0,16"/>
                                    <UniformGrid Columns="3">
                                        <Button Style="{StaticResource PrimaryButton}" Content="تشغيل المحطة" Click="StartShopStation_Click"/>
                                        <Button Content="فحص الآن" Click="RunShopOnce_Click"/>
                                        <Button Style="{StaticResource DangerButton}" Content="إيقاف" Click="StopShopStation_Click"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="المنشورات المستحقة" FontSize="23" FontWeight="Bold"/>
                                    <Button Content="تحديث القائمة" Click="RefreshDuePosts_Click" HorizontalAlignment="Right"/>
                                    <ListBox x:Name="DuePostsListBox" MinHeight="280" FontSize="15"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
